
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user or customer on the HomeHero platform.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "worker", "admin"] },
        "city": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "ServiceCategory": {
      "title": "ServiceCategory",
      "type": "object",
      "description": "Categories of services offered (e.g., Plumber, Electrician).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "iconName": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "WorkerProfile": {
      "title": "WorkerProfile",
      "type": "object",
      "description": "Detailed profile for a service provider.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "baseCharge": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "bio": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "availability": { "type": "string" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "city": { "type": "string" }
      },
      "required": ["id", "userId", "categoryId", "baseCharge"]
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "A service request or appointment between a customer and a worker.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "workerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "serviceDetails": { "type": "string" }
      },
      "required": ["id", "customerId", "workerId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Individual user data."
    },
    "/serviceCategories/{categoryId}": {
      "schema": "#/backend/entities/ServiceCategory",
      "description": "Global service categories."
    },
    "/workerProfiles/{workerId}": {
      "schema": "#/backend/entities/WorkerProfile",
      "description": "Publicly viewable worker profiles."
    },
    "/bookings/{bookingId}": {
      "schema": "#/backend/entities/Booking",
      "description": "Private booking records between users and workers."
    }
  }
}
