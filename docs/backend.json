
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a student, teacher, or admin on CampusNotes.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "branch": { "type": "string" },
        "semester": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role"]
    },
    "StudyMaterial": {
      "title": "StudyMaterial",
      "type": "object",
      "description": "An academic resource uploaded by a student or teacher.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "branch": { "type": "string" },
        "semester": { "type": "number" },
        "type": { "type": "string", "enum": ["Note", "Assignment", "Previous Year Paper", "Textbook", "Lab Manual", "YouTube Playlist"] },
        "fileUrl": { "type": "string", "format": "uri" },
        "author": { "type": "string" },
        "uploaderId": { "type": "string" },
        "downloadCount": { "type": "number" },
        "views": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "branch", "semester", "type", "fileUrl"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "type": "object",
      "description": "A discussion thread in the forum.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "branch": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "authorId"]
    },
    "ForumReply": {
      "title": "ForumReply",
      "type": "object",
      "description": "A comment or reply on a forum post.",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "content", "authorId"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "type": "object",
      "description": "A message sent via the contact form.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "System announcements or alerts.",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "targetRole": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile data."
    },
    "/studyMaterials/{materialId}": {
      "schema": "#/backend/entities/StudyMaterial",
      "description": "Collection of all study resources."
    },
    "/forumPosts/{postId}": {
      "schema": "#/backend/entities/ForumPost",
      "description": "Forum discussion threads."
    },
    "/forumPosts/{postId}/replies/{replyId}": {
      "schema": "#/backend/entities/ForumReply",
      "description": "Replies within a discussion thread."
    },
    "/contactMessages/{messageId}": {
      "schema": "#/backend/entities/ContactMessage",
      "description": "User messages from the contact form."
    },
    "/notifications/{notifId}": {
      "schema": "#/backend/entities/Notification",
      "description": "Global notifications."
    }
  }
}
