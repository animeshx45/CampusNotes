
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a student or contributor on CampusNotes.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email"]
    },
    "StudyMaterial": {
      "title": "StudyMaterial",
      "type": "object",
      "description": "An academic resource uploaded by a student.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "branch": { "type": "string" },
        "semester": { "type": "number" },
        "type": { "type": "string", "enum": ["Note", "Assignment", "Previous Year Paper", "Textbook", "Lab Manual", "YouTube Playlist"] },
        "fileUrl": { "type": "string", "format": "uri" },
        "author": { "type": "string" },
        "uploaderId": { "type": "string" },
        "downloadCount": { "type": "number" },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "branch", "semester", "type", "fileUrl"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile data."
    },
    "/studyMaterials/{materialId}": {
      "schema": "#/backend/entities/StudyMaterial",
      "description": "Collection of all study resources."
    }
  }
}
