
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public Access Rules for CampusNotes
    
    match /users/{userId} {
      allow read: if true;
      allow write: if false; 
    }

    match /studyMaterials/{id} {
      allow read: if true;
      allow create: if true; 
      allow update: if true;
      allow delete: if false; 
    }
    
    match /forumPosts/{id} {
      allow read: if true;
      allow create: if true; 
      allow delete: if false;

      match /replies/{replyId} {
        allow read: if true;
        allow create: if true; 
        allow delete: if false;
      }
    }

    match /contactMessages/{id} {
      allow read: if false; // Only admin should read via console
      allow create: if true; // Public can send messages
    }
    
    match /notifications/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
