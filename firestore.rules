
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /studyMaterials/{id} {
      allow read: if true;
      allow create: if true; // Allow anonymous contributions for MVP
      allow update: if true; // Allow view/download increments
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }
  }
}
