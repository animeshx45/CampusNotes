
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /materials/{materialId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount']);
      allow delete: if request.auth != null && (resource.data.authorEmail == request.auth.token.email || resource.data.authorId == request.auth.uid);
    }
  }
}
