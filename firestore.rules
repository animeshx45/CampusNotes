
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow list: if true;
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }

    match /studyMaterials/{id} {
      allow read: if true;
      allow create: if true;
      // Allow everyone to update to support view/download counts
      // In a production app, we would restrict which fields can be edited
      allow update: if true;
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }

    match /branches/{id} { allow read: if true; }
    match /semesters/{id} { allow read: if true; }
    match /materialTypes/{id} { allow read: if true; }
  }
}
