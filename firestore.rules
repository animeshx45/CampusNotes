
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /studyMaterials/{id} {
      allow read: if true;
      allow create: if isSignedIn(); // Require auth for uploads in Portal mode
      allow update: if true; // Allow view/download increments
      allow delete: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || getUserData().role == 'admin');
    }
    
    match /forumPosts/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || getUserData().role == 'admin');
    }
    
    match /notifications/{id} {
      allow read: if true;
      allow write: if isSignedIn() && getUserData().role == 'admin';
    }
  }
}
