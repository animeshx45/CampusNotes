rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NIT StudySync Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a robust, owner-based authorization model for user profiles and 
     * uploaded study materials, while maintaining public read access for academic metadata.
     * Administrative actions are controlled via a dedicated role-marker collection.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles managed by the authenticated owner.
     * - /studyMaterials/{id}: A global collection of academic resources, publicly readable, 
     *   but writable only by the original uploader (denormalized uploaderId).
     * - /branches, /semesters, /materialTypes: Master academic categories, publicly readable, 
     *   writable only by designated administrators.
     * - /roles_admin/{userId}: Marker collection for Database Access Control (DBAC).
     * 
     * Key Security Decisions:
     * - Denormalization: The 'uploaderId' is stored directly on 'StudyMaterial' documents 
     *   to allow for efficient, single-document authorization checks without extra lookups.
     * - Role Management: Administrative privileges are determined by the existence of 
     *   a document in the 'roles_admin' collection, preventing unauthorized data modification.
     * - Prototyping Flexibility: Rules focus on strict authorization (WHO can access) 
     *   while allowing flexible data shapes for rapid iteration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user has the admin role. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combined ownership and existence check for updates and deletes. */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Access is restricted to the account owner.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if request.auth.uid matches {userId}
     * @deny (create) if request.auth.uid does not match {userId}
     * @principle Restricts access to a user's own data tree using path-based ownership.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for academic branches. Publicly readable, admin writable.
     * @path /branches/{branchId}
     * @allow (get, list) for any user.
     * @allow (create, update, delete) only for users in roles_admin.
     * @principle Global lookup data is public, but management is restricted to admins.
     */
    match /branches/{branchId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for academic semesters. Publicly readable, admin writable.
     * @path /semesters/{semesterId}
     * @allow (get, list) for any user.
     * @allow (create, update, delete) only for users in roles_admin.
     * @principle Global lookup data is public, but management is restricted to admins.
     */
    match /semesters/{semesterId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for material types. Publicly readable, admin writable.
     * @path /materialTypes/{materialTypeId}
     * @allow (get, list) for any user.
     * @allow (create, update, delete) only for users in roles_admin.
     * @principle Global lookup data is public, but management is restricted to admins.
     */
    match /materialTypes/{materialTypeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for study materials. Anyone can browse; only uploaders can edit/delete.
     * @path /studyMaterials/{studyMaterialId}
     * @allow (get, list) for all users to facilitate browsing and search.
     * @allow (create) if the uploaderId in data matches the authenticated user.
     * @deny (update) if the uploaderId is changed or if the requester is not the owner.
     * @principle Enforces owner-only writes using denormalized 'uploaderId' field.
     */
    match /studyMaterials/{studyMaterialId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.uploaderId) || isAdmin()) && request.resource.data.uploaderId == resource.data.uploaderId;
      allow delete: if isExistingOwner(resource.data.uploaderId) || isAdmin();
    }

    /**
     * @description Rules for the admin role marker collection.
     * @path /roles_admin/{userId}
     * @allow (get) for the owner to check their own status.
     * @allow (list) only for existing admins.
     * @deny (create, update, delete) for all client requests (managed via backend/console).
     * @principle DBAC marker collection used for internal role validation.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}