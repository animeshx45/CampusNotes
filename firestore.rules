
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public Access Rules for CampusNotes
    
    match /users/{userId} {
      allow read: if true;
      allow write: if false; // Auth removed, writing users is no longer supported
    }

    match /studyMaterials/{id} {
      allow read: if true;
      allow create: if true; // Public uploads enabled
      allow update: if true;
      allow delete: if false; // Prevent public deletion
    }
    
    match /forumPosts/{id} {
      allow read: if true;
      allow create: if true; // Public discussions enabled
      allow delete: if false;

      match /replies/{replyId} {
        allow read: if true;
        allow create: if true; // Public replies enabled
        allow delete: if false;
      }
    }
    
    match /notifications/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
